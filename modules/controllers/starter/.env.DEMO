# Required
AMBITECTURE_HUB_URL=http://localhost:2612
NAME='Starter Controller'
GUID='starter-controller-1'

# Optional
GEO_LOCATION='0 0'

# Optional sample loop: when SAMPLE_INTENT_GUID is set, the controller
# drives that intent's position in a small circle via runtime:command.
# Leave SAMPLE_INTENT_GUID empty (or unset) to disable.
SAMPLE_INTENT_GUID=
SAMPLE_INTERVAL_MS=40
SAMPLE_RADIUS=1
